# Root .env for docker-compose.prod.yml (single-server deployment)
# Copy to .env at repo root, fill in values, then: docker compose -f docker-compose.prod.yml up -d

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=intervai

# Redis (leave blank for no password in internal Docker network)
REDIS_PASSWORD=

# Neon / external DB override (optional — leave blank to use local postgres service)
DATABASE_URL=

# Upstash / external Redis override (optional)
REDIS_URL=

# Same for Celery
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Clerk
CLERK_SECRET_KEY=sk_live_xxxxx
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# OpenAI
OPENAI_API_KEY=sk-proj-xxxxx

# CORS — comma-separated allowed frontend origins
CORS_ORIGINS=https://your-app.vercel.app

# Storage
STORAGE_BACKEND=local   # or s3
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Frontend
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Sentry (optional)
SENTRY_DSN=
