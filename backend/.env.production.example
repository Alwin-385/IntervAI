# ── Production environment variables ──────────────────────────────────────────
# Copy to .env on the server (or set as Railway/Render environment variables).
# NEVER commit this file with real values.

# Application
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=https://your-app.vercel.app,https://www.your-domain.com

# ── Neon PostgreSQL ────────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection string
# Format: postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/intervai?sslmode=require
DATABASE_URL=postgresql+asyncpg://neondb_owner:xxxxx@ep-xxx.us-east-2.aws.neon.tech/intervai?sslmode=require
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → REST → rediss:// URL
REDIS_URL=rediss://default:xxxxx@polite-xxxxx.upstash.io:6379
CELERY_BROKER_URL=rediss://default:xxxxx@polite-xxxxx.upstash.io:6379/1
CELERY_RESULT_BACKEND=rediss://default:xxxxx@polite-xxxxx.upstash.io:6379/2

# ── Qdrant Cloud ───────────────────────────────────────────────────────────────
# Get from: https://cloud.qdrant.io → Cluster → API
QDRANT_URL=https://xxxxx.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=xxxxx
RESUME_ANALYSIS_SKIP_EMBEDDINGS=false

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RESUME_ANALYSIS_HEURISTIC_ONLY=false
INTERVIEW_QUESTIONS_HEURISTIC_ONLY=false
INTERVIEW_QUESTIONS_USE_OPENAI=true
INTERVIEW_QUESTIONS_SKIP_RAG=false
ANSWER_EVALUATION_HEURISTIC_ONLY=false

# ── Clerk ──────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_xxxxx
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# ── Storage ────────────────────────────────────────────────────────────────────
# Option A — AWS S3 / Cloudflare R2 (recommended for production)
STORAGE_BACKEND=s3
S3_BUCKET=intervai-resumes-prod
S3_REGION=us-east-1
S3_ENDPOINT_URL=                # blank for AWS; set for R2: https://xxx.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=xxxxx
S3_SECRET_ACCESS_KEY=xxxxx
# Option B — local filesystem (single-server only, data lost on redeploy)
# STORAGE_BACKEND=local

# ── Background Jobs ────────────────────────────────────────────────────────────
BACKGROUND_JOBS_ENABLED=true
BACKGROUND_JOBS_MODE=celery

# ── Orchestration ──────────────────────────────────────────────────────────────
ORCHESTRATION_ENABLED=true
ORCHESTRATION_FEEDBACK_LLM=true

# ── Security ───────────────────────────────────────────────────────────────────
RATE_LIMITING_ENABLED=true
RATE_LIMIT_DEFAULT_RPM=120
RATE_LIMIT_AI_RPM=30
RATE_LIMIT_UPLOAD_RPM=10

# ── Monitoring ─────────────────────────────────────────────────────────────────
# Get DSN from: https://sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=https://xxxxx@oxxxxxxxx.ingest.sentry.io/xxxxx
SENTRY_TRACES_SAMPLE_RATE=0.1
