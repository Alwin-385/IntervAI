# Application
APP_NAME=AI Interview Intelligence Platform
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# API
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (use localhost for local dev, postgres for Docker Compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intervai
DATABASE_ECHO=false

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Clerk (from https://dashboard.clerk.com)
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev

# Resume storage (local or S3-compatible)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage/resumes
RESUME_MAX_SIZE_BYTES=5242880
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
