# Application
APP_NAME=AI Interview Intelligence Platform
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# API
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Database (use localhost for local dev, postgres for Docker Compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intervai
DATABASE_ECHO=false

# Redis / Celery (use localhost for local dev; use redis hostname inside Docker Compose)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# background = extract in API process after upload (default, no Celery worker needed)
# celery = requires Redis + .\scripts\start-celery.ps1
RESUME_EXTRACTION_MODE=background

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenAI (resume analysis — optional; heuristic fallback if empty)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_REQUEST_TIMEOUT_SECONDS=45
QDRANT_TIMEOUT_SECONDS=5
# Set true if Qdrant is not running — analysis completes in ~5–15s
RESUME_ANALYSIS_SKIP_EMBEDDINGS=true
# true = rigorous rubric-based scoring (no API key). false + OPENAI_API_KEY = GPT review
RESUME_ANALYSIS_HEURISTIC_ONLY=true
# Interview question generation (Phase 9)
INTERVIEW_QUESTIONS_HEURISTIC_ONLY=true
INTERVIEW_QUESTIONS_USE_OPENAI=false
INTERVIEW_QUESTIONS_SKIP_RAG=true
# Answer evaluation (Phase 13) — true = rubric scoring, no OpenAI
ANSWER_EVALUATION_HEURISTIC_ONLY=true

# LangGraph orchestration (Phase 17)
ORCHESTRATION_ENABLED=true
ORCHESTRATION_MAX_RETRIES=3
ORCHESTRATION_RETRY_DELAY_SECONDS=0.5
ORCHESTRATION_USE_LANGGRAPH_INVOKE=false
ORCHESTRATION_FEEDBACK_LLM=false

# Background jobs (Phase 18) — Celery + Redis
BACKGROUND_JOBS_ENABLED=true
BACKGROUND_JOBS_MODE=auto
BACKGROUND_JOBS_ASYNC_RESUME_EXTRACTION=true
BACKGROUND_JOBS_ASYNC_RESUME_ANALYSIS=true
BACKGROUND_JOBS_ASYNC_QUESTION_GENERATION=true
BACKGROUND_JOBS_ASYNC_ANSWER_EVALUATION=true
BACKGROUND_JOBS_ASYNC_ROADMAP_GENERATION=true

# Clerk (from https://dashboard.clerk.com)
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev

# Resume storage (local or S3-compatible)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage/resumes
STORAGE_AUDIO_PATH=./storage/audio
RESUME_MAX_SIZE_BYTES=5242880
SPEECH_MAX_SIZE_BYTES=26214400
# browser = free (Chrome/Edge speech while recording). whisper = paid OpenAI API.
SPEECH_TRANSCRIPTION_MODE=browser
OPENAI_WHISPER_MODEL=whisper-1
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Security (Phase 19)
RATE_LIMITING_ENABLED=true
RATE_LIMIT_DEFAULT_RPM=120
RATE_LIMIT_AI_RPM=30
RATE_LIMIT_UPLOAD_RPM=10

# Monitoring / Sentry (Phase 19) — leave blank to disable
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
